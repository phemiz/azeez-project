{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/design-system/(.*)",
      "dest": "/public/design-system/$1"
    },
    {
      "src": "/final_aligned_project_document.pdf",
      "dest": "/public/final_aligned_project_document.pdf"
    },
    {
      "src": "/install.php",
      "dest": "/api/install.php"
    },
    {
      "src": "/db-init.php",
      "dest": "/api/db-init.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
